<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@color/background" />
    <item android:gravity="center">
        <shape android:shape="oval">
            <solid android:color="@color/splash_ring" />
            <size android:width="260dp" android:height="260dp" />
        </shape>
    </item>
    <item android:gravity="center">
        <shape android:shape="oval">
            <stroke android:width="2dp" android:color="@color/primary" />
            <solid android:color="@android:color/transparent" />
            <size android:width="180dp" android:height="180dp" />
        </shape>
    </item>
    <item android:drawable="@mipmap/ic_launcher_foreground" android:gravity="center" android:width="96dp" android:height="96dp" />
</layer-list>